---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RestablecerPasswordForm from '../components/auth/RestablecerPasswordForm.tsx';
---

<Layout
  title="Restablecer Contraseña - FarmaTurno Chile"
  description="Establece una nueva contraseña para tu cuenta."
>
  <Header />

  <main class="grow container mx-auto px-4 py-8 md:py-12">
    <RestablecerPasswordForm client:load />
  </main>

  <Footer />
</Layout>
