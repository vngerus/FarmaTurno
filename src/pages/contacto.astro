---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactoForm from '../components/contacto/ContactoForm.tsx';
---

<Layout
  title="Contacto - FarmaTurno Chile"
  description="Escríbenos tus dudas, sugerencias o reportes sobre FarmaTurno Chile."
>
  <Header />

  <main class="grow container mx-auto px-4 py-10 md:py-16">
    <div class="max-w-xl mx-auto border-b-2 border-[#0f1f19] pb-6 mb-8 text-center">
      <span class="font-mono text-[13.5px] font-bold text-[#e8632c] tracking-wide uppercase">Contacto</span>
      <h1 class="mt-1.5 font-heading font-bold text-3xl md:text-4xl tracking-tight text-[#0f1f19]">
        Hablemos
      </h1>
      <p class="mt-2 text-sm text-brand-body">
        ¿Dudas, sugerencias o algo que reportar? Escríbenos.
      </p>
    </div>

    <ContactoForm client:load />
  </main>

  <Footer />
</Layout>
